# kgout environment variables
# Copy this file to .env and fill in your values.
# In Kaggle notebooks, use Kaggle Secrets instead of .env files.

# ngrok auth token (required for "local" destination)
# Get yours free at: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTH_TOKEN=

# Google Drive service account credentials JSON path (required for "gdrive" destination)
# See README.md for setup instructions
KGOUT_GDRIVE_CREDENTIALS=
